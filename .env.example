# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Application
SERVER_PORT=8080

# Database connection used by application-prod.yml
# Use the reachable production DB host, such as an RDS endpoint or another EC2/private IP.
DB_URL=jdbc:mysql://your-db-host:3306/memoreel?serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=memoreel
DB_PASSWORD=change-me
DB_DRIVER=com.mysql.cj.jdbc.Driver

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
